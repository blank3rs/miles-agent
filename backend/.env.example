# Azure AI — Kimi K2.6
AZURE_ENDPOINT=https://your-resource.services.ai.azure.com/openai/v1
AZURE_API_KEY=your-azure-api-key
MODEL=Kimi-K2.6

# OpenAI — embeddings (text-embedding-3-small) + Graphiti memory extraction (gpt-4o-mini)
OPENAI_API_KEY=your-openai-api-key

# Email — Gmail app password (myaccount.google.com/apppasswords)
EMAIL_ADDRESS=you@example.com        # account used for SMTP auth
EMAIL_ALIAS=agent@example.com        # address recipients see as From
EMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
IMAP_SERVER=imap.gmail.com
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# Keyring encryption password — required on Linux (generate: openssl rand -hex 32)
KEYRING_PASSWORD=

# Phone number that can receive SMS verification codes (E.164, e.g. +14155551234)
AKSHAY_PHONE=

# Voice (optional) — Twilio Media Streams <-> Gemini Live
GEMINI_API_KEY=
VOICE_PUBLIC_HOST=
VOICE_STREAM_TOKEN=

# Paths (local dev only; the container sets these via docker-compose)
HESO_ROOT=/path/to/heso
SANDBOX_ROOT=/path/to/heso/ceo-person-careful
