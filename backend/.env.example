# Azure AI — Kimi K2.6
AZURE_ENDPOINT=https://your-resource.services.ai.azure.com/openai/v1
AZURE_API_KEY=your-azure-api-key
MODEL=Kimi-K2.6

# OpenAI — embeddings (text-embedding-3-small) + Graphiti memory extraction (gpt-4o-mini)
OPENAI_API_KEY=your-openai-api-key

# HESO Action Receipts (optional) — sign + ledger every consequential action via the `heso` SDK.
# No-op unless HESO_API_KEY is set. One-time setup on the data volume: `heso init <DATA_DIR>`
# (scaffolds heso.toml + an encrypted signing identity), then set the passphrase below.
HESO_API_KEY=heso_live_...
HESO_ENDPOINT=https://api.heso.ca
HESO_KEY_PASSPHRASE=                  # passphrase for the identity key (REQUIRED in prod)
# HESO_PROJECT_ROOT=                  # defaults to DATA_DIR (where heso.toml + identity live)

# Email — Gmail app password (myaccount.google.com/apppasswords)
EMAIL_ADDRESS=you@example.com        # account used for SMTP auth
EMAIL_ALIAS=agent@example.com        # address recipients see as From
EMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
IMAP_SERVER=imap.gmail.com
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# Keyring encryption password — required on Linux (generate: openssl rand -hex 32)
KEYRING_PASSWORD=

# Phone number that can receive SMS verification codes (E.164, e.g. +14155551234)
AKSHAY_PHONE=

# Voice (optional) — Twilio Media Streams <-> Gemini Live
GEMINI_API_KEY=
VOICE_PUBLIC_HOST=
VOICE_STREAM_TOKEN=

# Paths (local dev only; the container sets these via docker-compose)
HESO_ROOT=/path/to/heso
SANDBOX_ROOT=/path/to/heso/ceo-person-careful

# Sandboxed code execution (exec_sandboxed). rlimits enforced on Linux only; tune for the VM.
SANDBOX_EXEC_CPU_SECONDS=10     # per-call CPU-second cap (RLIMIT_CPU)
SANDBOX_EXEC_MEM_MB=512         # per-call address-space cap (RLIMIT_AS), MB
SANDBOX_EXEC_FSIZE_MB=64        # per-call max file write size (RLIMIT_FSIZE), MB
SANDBOX_EXEC_TIMEOUT_S=30       # wall-clock timeout before the process group is SIGKILLed
SANDBOX_EXEC_MAX_PER_DAY=200    # daily run cap (runaway/loop guard)
SANDBOX_EXEC_MAX_OUTPUT=20000   # max chars of combined stdout/stderr returned
