# Miles CEO Agent — Production Environment Variables
# Copy this to /mnt/miles-data/.env on the VM and fill in the blanks.
# This file is NOT committed to git.

# Azure AI (Kimi K2.6)
AZURE_ENDPOINT=https://your-resource.services.ai.azure.com/openai/v1
AZURE_API_KEY=
MODEL=Kimi-K2.6

# OpenAI — used for embeddings (text-embedding-3-small) via Graphiti memory
# Get a key at platform.openai.com. Usage is minimal (~$1-2/mo).
OPENAI_API_KEY=

# Email — auth as akshay@heso.ca, send as miles@heso.ca
EMAIL_ADDRESS=akshay@heso.ca
EMAIL_ALIAS=miles@heso.ca
EMAIL_APP_PASSWORD=
IMAP_SERVER=imap.gmail.com
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# Keyring encryption password — required on Linux for secure secret storage.
# Generate one with: openssl rand -hex 32
KEYRING_PASSWORD=

# FalkorDB — set by docker-compose via environment:, do not override here
# FALKORDB_HOST=falkordb
# FALKORDB_PORT=6379

# Optional API key to protect /chat and /ws from unauthorized access.
# Leave blank to allow open access (restrict port 8000 via NSG instead).
MILES_API_KEY=

# Paths — set by docker-compose, do not change
HESO_ROOT=/heso
SANDBOX_ROOT=/data
